<Window x:Class="AutoLCPR.UI.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoLCPR - Sistema de Gestão Fiscal e Rebanho"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Bem-vindo ao AutoLCPR" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="#333" 
                       TextAlignment="Center" 
                       Margin="0,0,0,20"/>
            <TextBlock Text="Sistema de Gestão Fiscal e Rebanho Rural" 
                       FontSize="16" 
                       Foreground="#666" 
                       TextAlignment="Center"
                       Margin="0,0,0,40"/>
            <ProgressBar Height="4" IsIndeterminate="True"/>
            <TextBlock Text="Inicializando aplicação..." 
                       FontSize="14" 
                       Foreground="#999" 
                       TextAlignment="Center" 
                       Margin="0,20,0,0"/>
        </StackPanel>
    </Grid>
</Window>
