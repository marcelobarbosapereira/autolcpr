<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AutoLCPR.UI.WPF.Views"
        xmlns:vm="clr-namespace:AutoLCPR.UI.WPF.ViewModels"
        x:Class="AutoLCPR.UI.WPF.MainWindow"    
        mc:Ignorable="d"
Title="AutoLCPR"
        Height="800"
        Width="1300"
        Background="#F5F6FA"
        WindowStartupLocation="CenterScreen"
        Loaded="MainWindow_Loaded">

    <!-- ESTILOS -->
    <Window.Resources>
        <Style x:Key="SidebarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Margin" Value="0 0 0 10"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#2D3748"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Margin="10 0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EDF2F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataTemplates para Mapeamento de ViewModel → View -->
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <local:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProdutorViewModel}">
            <local:ProdutorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NotaFiscalViewModel}">
            <local:NotaFiscalView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RebanhoViewModel}">
            <local:RebanhoView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ImportarViewModel}">
            <local:ImportarView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConfiguracoesViewModel}">
            <local:ConfiguracoesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RelatoriosViewModel}">
            <local:RelatoriosView/>
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Background="White" Grid.Column="0">
            <StackPanel Margin="20">

                <Button Content="📄 Dashboard" 
                        Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding NavigateToHomeCommand}" FontSize="20"/>
                <Button Content=" ⬇️   Importar"
                        Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding NavigateToImportarCommand}" FontSize="20" HorizontalAlignment="Center" Width="179" Click="Button_Click"/>
                <Button Content="📊 Relatórios"
                        Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding NavigateToRelatoriosCommand}" FontSize="20" HorizontalAlignment="Center"/>
                <Button Content="⚙️ Configurações"
                        Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding NavigateToConfiguracoesCommand}" FontSize="20" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- CONTEÚDO PRINCIPAL -->
        <ContentControl Grid.Column="1" 
                        Content="{Binding CurrentView}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"/>
    </Grid>

</Window>

