<UserControl x:Class="AutoLCPR.UI.WPF.Views.NotaFiscalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8F9FA">
    <StackPanel Margin="30">
            <!-- Header -->
            <Border Background="White" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="20,15" Margin="0,0,0,20">
                <TextBlock Text="Cadastrar Nota Fiscal" 
                           FontSize="24" 
                           FontWeight="SemiBold" 
                           Foreground="#202124" HorizontalAlignment="Center"/>
            </Border>

            <!-- Form Container -->
            <Border Background="White" 
                    BorderBrush="#E8EAED" 
                    BorderThickness="1"
                    Padding="30"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Linha 1: Data de Emissão | Número da Nota Fiscal -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,20">
                        <TextBlock Text="Data de Emissão *" FontSize="14" FontWeight="SemiBold" Foreground="#202124" Margin="0,0,0,8"/>
                        <Border BorderBrush="#DADCE0" BorderThickness="1" CornerRadius="4">
                            <DatePicker SelectedDate="{Binding DataEmissao, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,10" FontSize="14" Background="White" BorderThickness="0" Foreground="#202124"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,20">
                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#202124" Margin="0,0,0,8"><Run Language="pt-br" Text="Número da Nota Fiscal *"/></TextBlock>
                        <Border BorderBrush="#DADCE0" BorderThickness="1" CornerRadius="4">
                            <TextBox Text="{Binding NumeroDaNota, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,10" FontSize="14" Background="White" BorderThickness="0" Foreground="#202124"/>
                        </Border>
                    </StackPanel>

                    <!-- Linha 2: Valor da Nota | Origem/Destino -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,20">
                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#202124" Margin="0,0,0,8"><Run Language="pt-br" Text="Valor da Nota Fiscal *"/></TextBlock>
                        <Border BorderBrush="#DADCE0" BorderThickness="1" CornerRadius="4">
                            <TextBox Text="{Binding ValorNotaFiscal, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,10" FontSize="14" Background="White" BorderThickness="0" Foreground="#202124"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,20">
                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#202124" Margin="0,0,0,8">
                            <TextBlock.Text>
                                <Binding Path="OrigemDestinoLabel"/>
                            </TextBlock.Text>
                        </TextBlock>
                        <Border BorderBrush="#DADCE0" BorderThickness="1" CornerRadius="4">
                            <!-- Campo combinado que mostra Origem ou Destino conforme tipo -->
                            <TextBox Text="{Binding OrigemDestinoValor, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,10" FontSize="14" Background="White" BorderThickness="0" Foreground="#202124"/>
                        </Border>
                    </StackPanel>

                    <!-- Linha 3: Descrição (2 colunas) -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,20">
                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#202124" Margin="0,0,0,8"><Run Language="pt-br" Text="Descrição"/></TextBlock>
                        <Border BorderBrush="#DADCE0" BorderThickness="1" CornerRadius="4">
                            <TextBox Text="{Binding Descricao, UpdateSourceTrigger=PropertyChanged}" Height="60" Padding="12,10" FontSize="14" Background="White" BorderThickness="0" Foreground="#202124" TextWrapping="Wrap" VerticalAlignment="Top"/>
                        </Border>
                    </StackPanel>

                    <!-- Linha 4: Botões -->
                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Command="{Binding SalvarCommand}" Content="Salvar" Padding="30,10" FontSize="14" FontWeight="SemiBold" Foreground="White" Background="#1F73E6" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
                        <Button Command="{Binding LimparCommand}" Content="Limpar" Padding="30,10" FontSize="14" FontWeight="SemiBold" Foreground="#1F73E6" Background="White" BorderBrush="#1F73E6" BorderThickness="1" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Info Box -->
            <Border Background="#E8F0FE" BorderBrush="#B4C7E7" BorderThickness="1" Padding="15" CornerRadius="4" Margin="0,20,0,0">
                <TextBlock Text="Campos marcados com * são obrigatórios." FontSize="12" Foreground="#1652AA" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
    </UserControl>
