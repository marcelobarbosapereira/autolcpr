<UserControl x:Class="AutoLCPR.UI.WPF.Views.ProdutorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8F9FA">
    <Border Background="White" BorderBrush="#E8EAED" BorderThickness="1" CornerRadius="8">
        <Grid Background="White">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" VerticalAlignment="Center" Background="White">
                <StackPanel Margin="30" VerticalAlignment="Center">
            <!-- Header -->
            <Border Background="White" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="20,15" Margin="0,0,0,20">
                <TextBlock Text="Cadastrar Produtor" 
                           FontSize="24" 
                           FontWeight="SemiBold" 
                           Foreground="#202124"/>
            </Border>

            <!-- Form Container -->
            <Border Background="White" 
                    BorderBrush="#E8EAED" 
                    BorderThickness="1"
                    Padding="30"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Nome do Produtor -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,20">
                        <TextBlock Text="Nome do Produtor" 
                                   FontSize="14" 
                                   FontWeight="SemiBold" 
                                   Foreground="#202124"
                                   Margin="0,0,0,8"/>
                        <Border BorderBrush="#DADCE0" BorderThickness="1" CornerRadius="4">
                            <TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}"
                                     Height="40"
                                     Padding="12,10"
                                     FontSize="14"
                                     Background="White"
                                     BorderThickness="0"
                                     Foreground="#202124"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,20">
                        <TextBlock Text="CPF do Produtor" 
                                   FontSize="14" 
                                   FontWeight="SemiBold" 
                                   Foreground="#202124"
                                   Margin="0,0,0,8"/>
                        <Border BorderBrush="#DADCE0" BorderThickness="1" CornerRadius="4">
                            <TextBox Text="{Binding Cpf, UpdateSourceTrigger=PropertyChanged}"
                                     Height="40"
                                     Padding="12,10"
                                     FontSize="14"
                                     Background="White"
                                     BorderThickness="0"
                                     Foreground="#202124"/>
                        </Border>
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Center"
                                Margin="0,30,0,0">
                        <Button Command="{Binding SalvarCommand}"
                                Content="Salvar"
                                Height="40"
                                Width="120"
                                Background="#1F71E7"
                                Foreground="White"
                                Padding="15,8"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                HorizontalContentAlignment="Center"
                                Margin="0,0,10,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Border BorderThickness="1" CornerRadius="4" BorderBrush="#1F73E6">
                            <Button Command="{Binding LimparCommand}"
                                    Content="Limpar"
                                    Height="40"
                                    Width="120"
                                    Padding="20,8"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="#1F73E6"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Info Box -->
            <Border Background="#E8F0FE" 
                    BorderBrush="#B4C7E7" 
                    BorderThickness="1"
                    Padding="15"
                    CornerRadius="4"
                    Margin="0,20,0,0">
                <TextBlock Text="Preencha o nome e o CPF do produtor e clique em Salvar para registrar." 
                           FontSize="12" 
                           Foreground="#1652AA"
                           TextWrapping="Wrap"/>
            </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
