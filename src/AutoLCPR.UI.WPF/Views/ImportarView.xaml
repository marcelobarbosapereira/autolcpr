<UserControl x:Class="AutoLCPR.UI.WPF.Views.ImportarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:local="clr-namespace:AutoLCPR.UI.WPF.Converters"
             Background="#F8F9FA">
    <UserControl.Resources>
        <local:FiltroToColorConverter x:Key="FiltroToColorConverter"/>
        <local:FiltroToLineColorConverter x:Key="FiltroToLineColorConverter"/>
        <local:FiltroToVisibilityConverter x:Key="FiltroToVisibilityConverter"/>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="White" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="20,15">
            <TextBlock Text="Importações"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#202124"
                       TextAlignment="Center"/>
        </Border>

        <!-- Main Content with Tabs -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E8EAED" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tabs Row -->
                <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Background="White">
                        <Button Command="{Binding SelecionarNotasFiscaisCommand}" 
                                Background="Transparent" 
                                Foreground="{Binding SecaoSelecionada, Converter={StaticResource FiltroToColorConverter}, ConverterParameter=NotasFiscais}"
                                Padding="15,8,15,8" 
                                HorizontalAlignment="Left" 
                                VerticalAlignment="Center" 
                                Cursor="Hand" 
                                BorderThickness="0" 
                                FontWeight="SemiBold" 
                                FontSize="12" 
                                Margin="0,0,20,0">
                            <TextBlock><Run Text="📄"/><Run Text=" Notas Fiscais"/></TextBlock>
                        </Button>
                        <Button Command="{Binding SelecionarExtratosCommand}" 
                                Background="Transparent"
                                Foreground="{Binding SecaoSelecionada, Converter={StaticResource FiltroToColorConverter}, ConverterParameter=Extratos}"
                                Padding="15,8,15,8" 
                                HorizontalAlignment="Left" 
                                VerticalAlignment="Center"
                                Cursor="Hand" 
                                BorderThickness="0" 
                                FontWeight="SemiBold" 
                                FontSize="12" 
                                Margin="0">
                            <TextBlock><Run Text="📋"/><Run Text=" Extratos"/></TextBlock>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Conteúdo das Abas -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20" Width="1200">

                        <!-- Aba: Notas Fiscais -->
                        <Grid Visibility="{Binding SecaoSelecionada, Converter={StaticResource FiltroToVisibilityConverter}, ConverterParameter=NotasFiscais}">
                            <Border Background="White"
                                    BorderBrush="#E8EAED"
                                    BorderThickness="1"
                                    Padding="16"
                                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Button Content="Abrir SEFAZ-MS no painel"
                                Height="36"
                                Margin="0,0,0,8"
                                Click="AbrirSite_Click"/>

                        <Button Content="Capturar NF-es"
                                Command="{Binding ExecutarImportacaoCommand}"
                                Height="38"
                                FontWeight="SemiBold"
                                Margin="0,0,0,14"/>

                        <Button Content="Importar"
                                Command="{Binding ImportarNotasCommand}"
                                Height="38"
                                FontWeight="SemiBold"
                                Margin="0,0,0,14"/>

                        <Border Background="#F7FAFC"
                                BorderBrush="#D7E3F4"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12"
                                Margin="0,0,0,14">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsProgressVisible}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding ProgressTitle}"
                                               FontWeight="SemiBold"
                                               Foreground="#1F2937"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ProgressSummary}"
                                               Foreground="#4B5563"/>
                                </Grid>

                                <ProgressBar Minimum="0"
                                             Maximum="{Binding ProgressMaximum, Mode=OneWay}"
                                             Value="{Binding ProgressValue, Mode=OneWay}"
                                             IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"
                                             Height="12"
                                             Margin="0,0,0,8"/>

                                <TextBlock Text="{Binding ProgressMessage}"
                                           TextWrapping="Wrap"
                                           Foreground="#5F6368"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{Binding Status}" Foreground="#5F6368" TextWrapping="Wrap" Margin="0,0,0,14"/>

                        <TextBlock Text="Chaves consultadas" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#202124"/>
                        <ListBox ItemsSource="{Binding ChavesImportadas}" Height="280"/>
                    </StackPanel>

                    <Border Grid.Column="2" BorderBrush="#E8EAED" BorderThickness="1" CornerRadius="6">
                        <wv2:WebView2 x:Name="SefazWebView" Height="700" />
                    </Border>
                </Grid>
            </Border>
                        </Grid>

                        <!-- Aba: Extratos -->
                        <Grid Visibility="{Binding SecaoSelecionada, Converter={StaticResource FiltroToVisibilityConverter}, ConverterParameter=Extratos}">
                            <Border Background="White"
                                    BorderBrush="#E8EAED"
                                    BorderThickness="1"
                                    Padding="20"
                                    CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Importar extrato do produtor"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#202124"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Esta seção é independente da importação de NF-es. O produtor utiliza apenas arquivos PDF de extrato."
                               Foreground="#5F6368"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14"/>

                    <TextBlock Text="A leitura automática do PDF será implementada para registrar: nome da propriedade, inscrição, saldo inicial, nascimentos, mortes/consumos, entradas, saídas e saldo final."
                               Foreground="#5F6368"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14"/>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding ArquivoExtratoSelecionado, Mode=OneWay}"
                                 Height="36"
                                 VerticalContentAlignment="Center"
                                 IsReadOnly="True"/>

                        <Button Grid.Column="2"
                            Content="Selecionar arquivo PDF"
                                Command="{Binding SelecionarArquivoExtratoCommand}"
                                Height="36"
                                FontWeight="SemiBold"/>

                        <Button Grid.Column="4"
                                Content="Importar extrato do produtor"
                                Command="{Binding ImportarExtratoCommand}"
                                Height="36"
                                FontWeight="SemiBold"/>
                    </Grid>

                    <TextBlock Text="{Binding ExtratoStatus}"
                               Foreground="#5F6368"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Campos previstos para leitura do extrato"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"
                               Foreground="#202124"/>

                    <ListBox ItemsSource="{Binding CamposExtratoRebanhoEsperados}"
                             Height="150"
                             Margin="0,0,0,10"/>

                    <TextBlock Text="Status da preparação"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"
                               Foreground="#202124"/>

                    <ListBox ItemsSource="{Binding LancamentosExtratoImportados}"
                             Height="220"/>
                </StackPanel>
            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
