<UserControl x:Class="AutoLCPR.UI.WPF.Views.ImportarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="#F8F9FA">
    <ScrollViewer>
        <StackPanel Margin="20" VerticalAlignment="Center" HorizontalAlignment="Center" Width="1200">
            <Border Background="White" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="20,15" Margin="0,0,0,16" Width="1200">
                <TextBlock Text="Consultar NF-es SEFAZ-MS"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#202124"
                           TextAlignment="Center"/>
            </Border>

            <Border Background="White"
                    BorderBrush="#E8EAED"
                    BorderThickness="1"
                    Padding="16"
                    CornerRadius="8"
                    Width="1200">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Button Content="Abrir SEFAZ-MS no painel"
                                Height="36"
                                Margin="0,0,0,8"
                                Click="AbrirSite_Click"/>

                        <Button Content="Capturar NF-es"
                                Command="{Binding ExecutarImportacaoCommand}"
                                Height="38"
                                FontWeight="SemiBold"
                                Margin="0,0,0,14"/>

                        <Button Content="Importar"
                                Command="{Binding ImportarNotasCommand}"
                                Height="38"
                                FontWeight="SemiBold"
                                Margin="0,0,0,14"/>

                        <Border Background="#F7FAFC"
                                BorderBrush="#D7E3F4"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12"
                                Margin="0,0,0,14">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsProgressVisible}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding ProgressTitle}"
                                               FontWeight="SemiBold"
                                               Foreground="#1F2937"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ProgressSummary}"
                                               Foreground="#4B5563"/>
                                </Grid>

                                <ProgressBar Minimum="0"
                                             Maximum="{Binding ProgressMaximum, Mode=OneWay}"
                                             Value="{Binding ProgressValue, Mode=OneWay}"
                                             IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"
                                             Height="12"
                                             Margin="0,0,0,8"/>

                                <TextBlock Text="{Binding ProgressMessage}"
                                           TextWrapping="Wrap"
                                           Foreground="#5F6368"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{Binding Status}" Foreground="#5F6368" TextWrapping="Wrap" Margin="0,0,0,14"/>

                        <TextBlock Text="Chaves consultadas" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#202124"/>
                        <ListBox ItemsSource="{Binding ChavesImportadas}" Height="280"/>
                    </StackPanel>

                    <Border Grid.Column="2" BorderBrush="#E8EAED" BorderThickness="1" CornerRadius="6">
                        <wv2:WebView2 x:Name="SefazWebView" Height="700" />
                    </Border>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
