<UserControl x:Class="AutoLCPR.UI.WPF.Views.RelatoriosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8F9FA">
    <ScrollViewer>
        <StackPanel Margin="30">
            <!-- Header -->
            <Border Background="White" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="20,15" Margin="0,0,0,20">
                <TextBlock Text="Relatórios" 
                           FontSize="24" 
                           FontWeight="SemiBold" 
                           Foreground="#202124"/>
            </Border>

            <!-- Placeholder para futura implementação -->
            <Border Background="White" 
                    BorderBrush="#E8EAED" 
                    BorderThickness="1"
                    Padding="40"
                    CornerRadius="8"
                    Margin="0,20,0,0">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="📊 Relatórios Avançados" 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               Foreground="#202124"
                               TextAlignment="Center"
                               Margin="0,0,0,15"/>
                    <TextBlock Text="Esta seção será utilizada para análises e relatórios detalhados sobre as operações fiscais e do rebanho." 
                               FontSize="14" 
                               Foreground="#5F6368"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="400"
                               Margin="0,0,0,20"/>
                    <TextBlock Text="Para visualizar despesas, receitas e rebanho em tempo real, acesse a Dashboard." 
                               FontSize="12" 
                               Foreground="#9AA0A6"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="400"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
