<UserControl x:Class="AutoLCPR.UI.WPF.Views.RelatoriosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:AutoLCPR.UI.WPF.Converters"
             Background="#F8F9FA">
    <UserControl.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="30" MaxWidth="1200" HorizontalAlignment="Stretch">
            <!-- Header -->
            <Border Background="White" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="20,15" Margin="0,0,0,20">
                <TextBlock Text="Relatórios"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#202124"/>
            </Border>

            <!-- Seção Livro Caixa -->
            <Border Background="White"
                    BorderBrush="#E8EAED"
                    BorderThickness="1"
                    Padding="24"
                    CornerRadius="8"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Livro Caixa"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#202124"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="Gere um relatório em PDF do Livro Caixa para um ano específico."
                               FontSize="13"
                               Foreground="#5F6368"
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"/>

                    <!-- Campo Ano Base -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Ano Base:"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#202124"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding AnoBase, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34"
                                 Padding="10,6"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,16,0"/>
                    </Grid>

                    <!-- Botão Gerar -->
                    <Button Content="📄 Gerar Livro-Caixa"
                            Command="{Binding GerarLivroCaixaCommand}"
                            Width="200"
                            Height="40"
                            HorizontalAlignment="Left"
                            Background="#1A73E8"
                            Foreground="White"
                            BorderBrush="#1A73E8"
                            FontWeight="SemiBold"
                            FontSize="14"
                            Cursor="Hand"
                            IsEnabled="{Binding Carregando, Converter={StaticResource InverseBooleanConverter}}"
                            Margin="0,0,0,16"/>

                    <!-- Status -->
                    <TextBlock Text="{Binding Status}"
                               FontSize="12"
                               Foreground="#5F6368"
                               TextWrapping="Wrap"/>

                    <!-- Indicador de Carregamento -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0" Visibility="{Binding Carregando, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="⏳ Gerando relatório..."
                                   FontSize="12"
                                   Foreground="#1A73E8"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Informações -->
            <Border Background="#FFF3CD"
                    BorderBrush="#FFC107"
                    BorderThickness="1"
                    Padding="16"
                    CornerRadius="8"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="ℹ️ Informações"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#664D03"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="O relatório inclui demonstrativo de receitas e despesas, gráficos comparativos e detalhamento mensal. O arquivo PDF será aberto automaticamente após a geração."
                               FontSize="12"
                               Foreground="#664D03"
                               TextWrapping="Wrap"
                               LineHeight="18"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
