<UserControl x:Class="AutoLCPR.UI.WPF.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8F9FA">
    <ScrollViewer>
        <StackPanel>
            <!-- Header -->
            <Border Background="White" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="30,20">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="AutoLCPR" 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               Foreground="#202124"
                               Margin="0,0,10,0"/>
                    <TextBlock Text="Sistema Fiscal e Rebanho Rural" 
                               FontSize="14" 
                               Foreground="#5F6368"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- KPI Cards -->
            <StackPanel Orientation="Horizontal" Margin="30,25,30,20">
                <!-- Card: Saldo Atual -->
                <Border Background="White" 
                        BorderBrush="#E8EAED" 
                        BorderThickness="1"
                        Padding="20" 
                        Margin="0,0,20,0"
                        MinWidth="260">
                    <StackPanel>
                        <TextBlock Text="Saldo Atual" 
                                   FontSize="12" 
                                   Foreground="#5F6368"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="R$ 125.401,96" 
                                   FontSize="28" 
                                   FontWeight="SemiBold" 
                                   Foreground="#0F9747"/>
                    </StackPanel>
                </Border>

                <!-- Card: Receitas do Mês -->
                <Border Background="White" 
                        BorderBrush="#E8EAED" 
                        BorderThickness="1"
                        Padding="20" 
                        Margin="0,0,20,0"
                        MinWidth="260">
                    <StackPanel>
                        <TextBlock Text="Receitas do Mês" 
                                   FontSize="12" 
                                   Foreground="#5F6368"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="R$ 42.300,00" 
                                   FontSize="28" 
                                   FontWeight="SemiBold" 
                                   Foreground="#0F9747"/>
                    </StackPanel>
                </Border>

                <!-- Card: Despesas do Mês -->
                <Border Background="White" 
                        BorderBrush="#E8EAED" 
                        BorderThickness="1"
                        Padding="20" 
                        MinWidth="260">
                    <StackPanel>
                        <TextBlock Text="Despesas do Mês" 
                                   FontSize="12" 
                                   Foreground="#5F6368"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="R$ 31.180,00" 
                                   FontSize="28" 
                                   FontWeight="SemiBold" 
                                   Foreground="#D5433E"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Content Area -->
            <Border Background="White" 
                    BorderBrush="#E8EAED" 
                    BorderThickness="1" 
                    Margin="30,0,30,30">
                <StackPanel>
                    <!-- Tab Navigation -->
                    <StackPanel Orientation="Horizontal" Background="White">
                        <Button Background="Transparent" 
                                Foreground="#D5433E" 
                                Padding="20,15,20,15" 
                                HorizontalAlignment="Left"
                                HorizontalContentAlignment="Center"
                                Cursor="Hand"
                                BorderThickness="0,3,0,0"
                                BorderBrush="#D5433E"
                                FontWeight="SemiBold"
                                FontSize="12">
                            <TextBlock>
                                <Run Text="💰"/>
                                <Run Text=" Despesas"/>
                            </TextBlock>
                        </Button>

                        <Button Background="Transparent" 
                                Foreground="#5F6368" 
                                Padding="20,15,20,15" 
                                HorizontalAlignment="Left"
                                HorizontalContentAlignment="Center"
                                Cursor="Hand"
                                BorderThickness="0,3,0,0"
                                BorderBrush="Transparent"
                                FontWeight="Normal"
                                FontSize="12">
                            <TextBlock>
                                <Run Text="📈"/>
                                <Run Text=" Receitas"/>
                            </TextBlock>
                        </Button>

                        <Button Background="Transparent" 
                                Foreground="#5F6368" 
                                Padding="20,15,20,15" 
                                HorizontalAlignment="Left"
                                HorizontalContentAlignment="Center"
                                Cursor="Hand"
                                BorderThickness="0,3,0,0"
                                BorderBrush="Transparent"
                                FontWeight="Normal"
                                FontSize="12">
                            <TextBlock>
                                <Run Text="🐄"/>
                                <Run Text=" Rebanho"/>
                            </TextBlock>
                        </Button>
                    </StackPanel>

                    <!-- Search and Action Bar -->
                    <Border BorderBrush="#E8EAED" BorderThickness="0,1,0,0" Padding="20">
                        <StackPanel Orientation="Horizontal">
                            <TextBox Width="250" 
                                     Padding="10" 
                                     Text="Buscar..." 
                                     Foreground="#9AA0A6"
                                     Background="#F1F3F4"
                                     BorderBrush="#E8EAED"
                                     Margin="0,0,15,0"/>
                            <Button Background="#1F71E7" 
                                    Foreground="White" 
                                    Padding="15,8" 
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    HorizontalAlignment="Right"
                                    HorizontalContentAlignment="Center">
                                <TextBlock>
                                    <Run Text="➕"/>
                                    <Run Text=" Nova despesa"/>
                                </TextBlock>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Table Header -->
                    <Border BorderBrush="#E8EAED" BorderThickness="0,1,0,0" Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Data" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                            <TextBlock Grid.Column="1" Text="Vto/Pgto" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                            <TextBlock Grid.Column="2" Text="Documento" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                            <TextBlock Grid.Column="3" Text="Descrição da despesa" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                            <TextBlock Grid.Column="4" Text="Fornecedor" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                            <TextBlock Grid.Column="5" Text="Valor" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>

                            <!-- Sample Data Row 1 -->
                            <TextBlock Grid.Column="0" Text="05/02/2026" Margin="0,15,0,0" FontSize="12" Foreground="#202124"/>
                            <TextBlock Grid.Column="1" Text="2034" Margin="0,15,0,0" FontSize="12" Foreground="#202124"/>
                            <TextBlock Grid.Column="2" Text="2034" Margin="0,15,0,0" FontSize="12" Foreground="#202124"/>
                            <TextBlock Grid.Column="3" Text="Pagamento Aluguel" Margin="0,15,0,0" FontSize="12" Foreground="#202124"/>
                            <TextBlock Grid.Column="4" Text="Imobiliária X" Margin="0,15,0,0" FontSize="12" Foreground="#202124"/>
                            <TextBlock Grid.Column="5" Text="R$ 2" Margin="0,15,0,0" FontSize="12" Foreground="#202124"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
