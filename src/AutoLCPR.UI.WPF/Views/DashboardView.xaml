<UserControl x:Class="AutoLCPR.UI.WPF.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:AutoLCPR.UI.WPF.Converters"
    Background="#F8F9FA">
    <UserControl.Resources>
        <local:FiltroToColorConverter x:Key="FiltroToColorConverter"/>
        <local:FiltroToLineColorConverter x:Key="FiltroToLineColorConverter"/>
        <local:FiltroToWidthConverter x:Key="FiltroToWidthConverter"/>
        <local:FiltroToVisibilityConverter x:Key="FiltroToVisibilityConverter"/>
        <local:RebanhoSelectionConverter x:Key="RebanhoSelectionConverter"/>
        <local:NotaFiscalSelectionConverter x:Key="NotaFiscalSelectionConverter"/>
        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="#5F6368"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost"/>
                            <TextBlock x:Name="Watermark"
                                       Text="Buscar..."
                                       Foreground="#9AA0A6"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Watermark" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="White" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="20,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Produtor:" FontSize="18" FontWeight="SemiBold" Foreground="#202124" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Width="300"
                        Height="35"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"
                        Style="{StaticResource ModernComboBox}"
                        IsEditable="True"
                        ItemsSource="{Binding Produtores}"
                        SelectedItem="{Binding ProdutorSelecionado}"
                        DisplayMemberPath="Nome" FontSize="16"/>
                <Button Content="✏️" Background="#4CAF50" Foreground="White" Width="40" Height="35" FontSize="14" FontWeight="SemiBold" Cursor="Hand" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Command="{Binding EditarProdutorCommand}" Margin="0,0,5,0" ToolTip="Editar Produtor">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="+" Background="#1F71E7" Foreground="White" Width="40" Height="35" FontSize="18" FontWeight="SemiBold" Cursor="Hand" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Command="{Binding AdicionarProdutorCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="-" Background="#D5433E" Foreground="White" Width="40" Height="35" FontSize="18" FontWeight="SemiBold" Cursor="Hand" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Command="{Binding ExcluirProdutorCommand}" Margin="5,0,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E8EAED" BorderThickness="0,1,1,1" Margin="0,0,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tabs Row -->
                <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Background="White">
                        <Button Command="{Binding SelecionarDespesasCommand}" Background="Transparent" 
                                Foreground="{Binding FiltroSelecionado, Converter={StaticResource FiltroToColorConverter}, ConverterParameter=Despesas}"
                                Padding="15,8,15,8" HorizontalAlignment="Left" VerticalAlignment="Center" 
                                Cursor="Hand" BorderThickness="0" FontWeight="SemiBold" FontSize="12" Margin="0,0,20,0">
                            <TextBlock><Run Text="💸"/><Run Text=" Despesas"/></TextBlock>
                        </Button>
                        <Button Command="{Binding SelecionarReceitasCommand}" Background="Transparent"
                                Foreground="{Binding FiltroSelecionado, Converter={StaticResource FiltroToColorConverter}, ConverterParameter=Receitas}"
                                Padding="15,8,15,8" HorizontalAlignment="Left" VerticalAlignment="Center"
                                Cursor="Hand" BorderThickness="0" FontWeight="SemiBold" FontSize="12" Margin="0,0,20,0">
                            <TextBlock><Run Text="💰"/><Run Text=" Receitas"/></TextBlock>
                        </Button>
                        <Button Command="{Binding SelecionarRebanhoCommand}" Background="Transparent"
                                Foreground="{Binding FiltroSelecionado, Converter={StaticResource FiltroToColorConverter}, ConverterParameter=Rebanho}"
                                Padding="15,8,15,8" HorizontalAlignment="Left" VerticalAlignment="Center"
                                Cursor="Hand" BorderThickness="0" FontWeight="SemiBold" FontSize="12" Margin="0">
                            <TextBlock><Run Text="🐄"/><Run Text=" Propriedade"/></TextBlock>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- New Button Section -->
                <Border Grid.Row="1" BorderBrush="#E8EAED" BorderThickness="0,1,0,0" Padding="20">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content=" + " Background="#1F71E7" Foreground="White" 
                                Width="36" Height="32" FontSize="12" FontWeight="SemiBold" Cursor="Hand" 
                                HorizontalContentAlignment="Center" Margin="0"
                                Command="{Binding NovoItemCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content=" - " Background="#D5433E" Foreground="White" 
                                Width="36" Height="32" FontSize="12" FontWeight="SemiBold" Cursor="Hand" 
                                HorizontalContentAlignment="Center" Margin="8,0,12,0"
                                Command="{Binding ExcluirItemCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Border Background="#F5F7FA" BorderBrush="#E3E6EA" BorderThickness="1"
                                CornerRadius="6" Padding="10,4" Width="260" Height="32"
                                VerticalAlignment="Center">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔍" FontSize="12" Foreground="#9AA0A6"
                                           VerticalAlignment="Center" Margin="2,0,6,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SearchTextBoxStyle}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Despesas Grid -->
                        <Grid Visibility="{Binding FiltroSelecionado, Converter={StaticResource FiltroToVisibilityConverter}, ConverterParameter=Despesas}">
                            <StackPanel>
                                <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Data Emissão" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                                        <TextBlock Grid.Column="1" Text="Número NF" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                                        <TextBlock Grid.Column="2" Text="Origem" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                                        <TextBlock Grid.Column="3" Text="Descrição" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                                        <TextBlock Grid.Column="4" Text="Valor" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                                    </Grid>
                                </Border>
                                <ItemsControl ItemsSource="{Binding Despesas}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="20"
                                                    Cursor="Hand"
                                                    MouseLeftButtonDown="Border_MouseLeftButtonDown">
                                                <Border.InputBindings>
                                                    <MouseBinding Gesture="LeftDoubleClick" 
                                                                  Command="{Binding DataContext.EditarNotaFiscalCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                  CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Value="True">
                                                                <DataTrigger.Binding>
                                                                    <MultiBinding Converter="{StaticResource NotaFiscalSelectionConverter}">
                                                                        <Binding />
                                                                        <Binding Path="DataContext.NotaFiscalSelecionada" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                    </MultiBinding>
                                                                </DataTrigger.Binding>
                                                                <Setter Property="Background" Value="#CCE8FF"/>
                                                            </DataTrigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#E5F3FF"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="120"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding DataEmissao, StringFormat=dd/MM/yyyy}" FontSize="12" Foreground="#202124"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding NumeroDaNota}" FontSize="12" Foreground="#202124"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Origem}" FontSize="12" Foreground="#202124"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Descricao}" FontSize="12" Foreground="#202124"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding ValorNotaFiscal, StringFormat=R$ {0:N2}}" FontSize="12" Foreground="#202124" FontWeight="SemiBold"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>

                        <!-- Receitas Grid -->
                        <Grid Visibility="{Binding FiltroSelecionado, Converter={StaticResource FiltroToVisibilityConverter}, ConverterParameter=Receitas}">
                            <StackPanel>
                                <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Data Emissão" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                                        <TextBlock Grid.Column="1" Text="Número NF" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                                        <TextBlock Grid.Column="2" Text="Destino" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                                        <TextBlock Grid.Column="3" Text="Descrição" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                                        <TextBlock Grid.Column="4" Text="Valor" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                                    </Grid>
                                </Border>
                                <ItemsControl ItemsSource="{Binding Receitas}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="20"
                                                    Cursor="Hand"
                                                    MouseLeftButtonDown="Border_MouseLeftButtonDown">
                                                <Border.InputBindings>
                                                    <MouseBinding Gesture="LeftDoubleClick" 
                                                                  Command="{Binding DataContext.EditarNotaFiscalCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                  CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Value="True">
                                                                <DataTrigger.Binding>
                                                                    <MultiBinding Converter="{StaticResource NotaFiscalSelectionConverter}">
                                                                        <Binding />
                                                                        <Binding Path="DataContext.NotaFiscalSelecionada" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                    </MultiBinding>
                                                                </DataTrigger.Binding>
                                                                <Setter Property="Background" Value="#CCE8FF"/>
                                                            </DataTrigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#E5F3FF"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="120"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding DataEmissao, StringFormat=dd/MM/yyyy}" FontSize="12" Foreground="#202124"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding NumeroDaNota}" FontSize="12" Foreground="#202124"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Destino}" FontSize="12" Foreground="#202124"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Descricao}" FontSize="12" Foreground="#202124"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding ValorNotaFiscal, StringFormat=R$ {0:N2}}" FontSize="12" Foreground="#202124" FontWeight="SemiBold"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>

                        <!-- Rebanho Grid -->
                        <Grid Visibility="{Binding FiltroSelecionado, Converter={StaticResource FiltroToVisibilityConverter}, ConverterParameter=Rebanho}">
                            <StackPanel>
                                <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Inscrição" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                                        <TextBlock Grid.Column="1" Text="Nome" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                                        <TextBlock Grid.Column="2" Text="Nascimentos" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                                        <TextBlock Grid.Column="3" Text="Entradas" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                                        <TextBlock Grid.Column="4" Text="Saídas" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                                        <TextBlock Grid.Column="5" Text="Mortes" FontSize="12" FontWeight="SemiBold" Foreground="#5F6368"/>
                                    </Grid>
                                </Border>
                                <ItemsControl ItemsSource="{Binding Rebanhos}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="20" 
                                                    Cursor="Hand"
                                                    MouseLeftButtonDown="Border_MouseLeftButtonDown">
                                                <Border.InputBindings>
                                                    <MouseBinding Gesture="LeftDoubleClick" 
                                                                  Command="{Binding DataContext.EditarRebanhoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                  CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Value="True">
                                                                <DataTrigger.Binding>
                                                                    <MultiBinding Converter="{StaticResource RebanhoSelectionConverter}">
                                                                        <Binding />
                                                                        <Binding Path="DataContext.RebanhoSelecionado" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                    </MultiBinding>
                                                                </DataTrigger.Binding>
                                                                <Setter Property="Background" Value="#CCE8FF"/>
                                                            </DataTrigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#E5F3FF"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="100"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding IdRebanho}" FontSize="12" Foreground="#202124"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding NomeRebanho}" FontSize="12" Foreground="#202124"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Nascimentos}" FontSize="12" Foreground="#202124"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Entradas}" FontSize="12" Foreground="#202124"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding Saidas}" FontSize="12" Foreground="#202124"/>
                                                    <TextBlock Grid.Column="5" Text="{Binding Mortes}" FontSize="12" Foreground="#202124"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>