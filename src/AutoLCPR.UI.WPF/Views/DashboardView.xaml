<UserControl x:Class="AutoLCPR.UI.WPF.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:AutoLCPR.UI.WPF.Converters"
    Background="#F8F9FA">
    <UserControl.Resources>
        <local:FiltroToColorConverter x:Key="FiltroToColorConverter"/>
        <local:FiltroToLineColorConverter x:Key="FiltroToLineColorConverter"/>
        <local:FiltroToWidthConverter x:Key="FiltroToWidthConverter"/>
        <local:FiltroToVisibilityConverter x:Key="FiltroToVisibilityConverter"/>
        <local:RebanhoSelectionConverter x:Key="RebanhoSelectionConverter"/>
        <local:NotaFiscalSelectionConverter x:Key="NotaFiscalSelectionConverter"/>
        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="#5F6368"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost"/>
                            <TextBlock x:Name="Watermark"
                                       Text="Buscar..."
                                       Foreground="#9AA0A6"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Watermark" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="White" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="20,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Produtor:" FontSize="18" FontWeight="SemiBold" Foreground="#202124" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Width="300"
                        Height="35"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"
                        Style="{StaticResource ModernComboBox}"
                        IsEditable="True"
                        ItemsSource="{Binding Produtores}"
                        SelectedItem="{Binding ProdutorSelecionado}"
                        DisplayMemberPath="Nome" FontSize="16"/>
                <Button Content="✏️" Background="#4CAF50" Foreground="White" Width="40" Height="35" FontSize="14" FontWeight="SemiBold" Cursor="Hand" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Command="{Binding EditarProdutorCommand}" Margin="0,0,5,0" ToolTip="Editar Produtor">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="+" Background="#1F71E7" Foreground="White" Width="40" Height="35" FontSize="18" FontWeight="SemiBold" Cursor="Hand" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Command="{Binding AdicionarProdutorCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="-" Background="#D5433E" Foreground="White" Width="40" Height="35" FontSize="18" FontWeight="SemiBold" Cursor="Hand" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Command="{Binding ExcluirProdutorCommand}" Margin="5,0,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E8EAED" BorderThickness="0,1,1,1" Margin="0,0,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tabs Row -->
                <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Background="White">
                        <Button Command="{Binding SelecionarDespesasCommand}" Background="Transparent" 
                                Foreground="{Binding FiltroSelecionado, Converter={StaticResource FiltroToColorConverter}, ConverterParameter=Despesas}"
                                Padding="15,8,15,8" HorizontalAlignment="Left" VerticalAlignment="Center" 
                                Cursor="Hand" BorderThickness="0" FontWeight="SemiBold" FontSize="12" Margin="0,0,20,0">
                            <TextBlock><Run Text="💸"/><Run Text=" Despesas"/></TextBlock>
                        </Button>
                        <Button Command="{Binding SelecionarReceitasCommand}" Background="Transparent"
                                Foreground="{Binding FiltroSelecionado, Converter={StaticResource FiltroToColorConverter}, ConverterParameter=Receitas}"
                                Padding="15,8,15,8" HorizontalAlignment="Left" VerticalAlignment="Center"
                                Cursor="Hand" BorderThickness="0" FontWeight="SemiBold" FontSize="12" Margin="0,0,20,0">
                            <TextBlock><Run Text="💰"/><Run Text=" Receitas"/></TextBlock>
                        </Button>
                        <Button Command="{Binding SelecionarRebanhoCommand}" Background="Transparent"
                                Foreground="{Binding FiltroSelecionado, Converter={StaticResource FiltroToColorConverter}, ConverterParameter=Rebanho}"
                                Padding="15,8,15,8" HorizontalAlignment="Left" VerticalAlignment="Center"
                                Cursor="Hand" BorderThickness="0" FontWeight="SemiBold" FontSize="12" Margin="0">
                            <TextBlock><Run Text="🐄"/><Run Text=" Propriedade"/></TextBlock>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- New Button Section -->
                <Border Grid.Row="1" BorderBrush="#E8EAED" BorderThickness="0,1,0,0" Padding="20">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content=" + " Background="#1F71E7" Foreground="White" 
                                Width="36" Height="32" FontSize="12" FontWeight="SemiBold" Cursor="Hand" 
                                HorizontalContentAlignment="Center" Margin="0"
                                Command="{Binding NovoItemCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content=" - " Background="#D5433E" Foreground="White" 
                                Width="36" Height="32" FontSize="12" FontWeight="SemiBold" Cursor="Hand" 
                                HorizontalContentAlignment="Center" Margin="8,0,12,0"
                                Command="{Binding ExcluirItemCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Border Background="#F5F7FA" BorderBrush="#E3E6EA" BorderThickness="1"
                                CornerRadius="6" Padding="10,4" Width="260" Height="32"
                                VerticalAlignment="Center">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔍" FontSize="12" Foreground="#9AA0A6"
                                           VerticalAlignment="Center" Margin="2,0,6,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SearchTextBoxStyle}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Despesas Grid -->
                        <Grid Visibility="{Binding FiltroSelecionado, Converter={StaticResource FiltroToVisibilityConverter}, ConverterParameter=Despesas}">
                            <DataGrid ItemsSource="{Binding Despesas}"
                                      SelectedItem="{Binding NotaFiscalSelecionada}"
                                      AutoGenerateColumns="False"
                                      CanUserResizeColumns="True"
                                      CanUserResizeRows="False"
                                      CanUserReorderColumns="False"
                                      CanUserSortColumns="True"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      BorderThickness="0"
                                      Background="White"
                                      RowBackground="Transparent"
                                      AlternatingRowBackground="#F8F9FA"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="Foreground" Value="#5F6368"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="20,12"/>
                                        <Setter Property="BorderBrush" Value="#E8EAED"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E5F3FF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#CCE8FF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="20,12"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Foreground" Value="#202124"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="#202124"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Data Emissão" Binding="{Binding DataEmissao, StringFormat=dd/MM/yyyy}" Width="120" MinWidth="100"/>
                                    <DataGridTextColumn Header="Número NF" Binding="{Binding NumeroDaNota}" Width="140" MinWidth="100"/>
                                    <DataGridTextColumn Header="Origem" Binding="{Binding Origem}" Width="180" MinWidth="120"/>
                                    <DataGridTextColumn Header="Descrição" Binding="{Binding Descricao}" Width="*" MinWidth="200"/>
                                    <DataGridTextColumn Header="Valor" Binding="{Binding ValorNotaFiscal, StringFormat=R$ {0:N2}}" Width="140" MinWidth="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                                <DataGrid.InputBindings>
                                    <MouseBinding Gesture="LeftDoubleClick" 
                                                  Command="{Binding EditarNotaFiscalCommand}" 
                                                  CommandParameter="{Binding NotaFiscalSelecionada}"/>
                                </DataGrid.InputBindings>
                            </DataGrid>
                        </Grid>

                        <!-- Receitas Grid -->
                        <Grid Visibility="{Binding FiltroSelecionado, Converter={StaticResource FiltroToVisibilityConverter}, ConverterParameter=Receitas}">
                            <DataGrid ItemsSource="{Binding Receitas}"
                                      SelectedItem="{Binding NotaFiscalSelecionada}"
                                      AutoGenerateColumns="False"
                                      CanUserResizeColumns="True"
                                      CanUserResizeRows="False"
                                      CanUserReorderColumns="False"
                                      CanUserSortColumns="True"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      BorderThickness="0"
                                      Background="White"
                                      RowBackground="Transparent"
                                      AlternatingRowBackground="#F8F9FA"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="Foreground" Value="#5F6368"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="20,12"/>
                                        <Setter Property="BorderBrush" Value="#E8EAED"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E5F3FF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#CCE8FF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="20,12"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Foreground" Value="#202124"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="#202124"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Data Emissão" Binding="{Binding DataEmissao, StringFormat=dd/MM/yyyy}" Width="120" MinWidth="100"/>
                                    <DataGridTextColumn Header="Número NF" Binding="{Binding NumeroDaNota}" Width="140" MinWidth="100"/>
                                    <DataGridTextColumn Header="Destino" Binding="{Binding Destino}" Width="180" MinWidth="120"/>
                                    <DataGridTextColumn Header="Descrição" Binding="{Binding Descricao}" Width="*" MinWidth="200"/>
                                    <DataGridTextColumn Header="Valor" Binding="{Binding ValorNotaFiscal, StringFormat=R$ {0:N2}}" Width="140" MinWidth="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                                <DataGrid.InputBindings>
                                    <MouseBinding Gesture="LeftDoubleClick" 
                                                  Command="{Binding EditarNotaFiscalCommand}" 
                                                  CommandParameter="{Binding NotaFiscalSelecionada}"/>
                                </DataGrid.InputBindings>
                            </DataGrid>
                        </Grid>

                        <!-- Rebanho Grid -->
                        <Grid Visibility="{Binding FiltroSelecionado, Converter={StaticResource FiltroToVisibilityConverter}, ConverterParameter=Rebanho}">
                            <DataGrid ItemsSource="{Binding Rebanhos}"
                                      SelectedItem="{Binding RebanhoSelecionado}"
                                      AutoGenerateColumns="False"
                                      CanUserResizeColumns="True"
                                      CanUserResizeRows="False"
                                      CanUserReorderColumns="False"
                                      CanUserSortColumns="True"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      BorderThickness="0"
                                      Background="White"
                                      RowBackground="Transparent"
                                      AlternatingRowBackground="#F8F9FA"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="Foreground" Value="#5F6368"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="20,12"/>
                                        <Setter Property="BorderBrush" Value="#E8EAED"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E5F3FF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#CCE8FF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="20,12"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Foreground" Value="#202124"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="#202124"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Inscrição" Binding="{Binding IdRebanho}" Width="100" MinWidth="80"/>
                                    <DataGridTextColumn Header="Nome" Binding="{Binding NomeRebanho}" Width="*" MinWidth="150"/>
                                    <DataGridTextColumn Header="Nascimentos" Binding="{Binding Nascimentos}" Width="130" MinWidth="100"/>
                                    <DataGridTextColumn Header="Entradas" Binding="{Binding Entradas}" Width="110" MinWidth="90"/>
                                    <DataGridTextColumn Header="Saídas" Binding="{Binding Saidas}" Width="110" MinWidth="90"/>
                                    <DataGridTextColumn Header="Mortes" Binding="{Binding Mortes}" Width="110" MinWidth="90"/>
                                </DataGrid.Columns>
                                <DataGrid.InputBindings>
                                    <MouseBinding Gesture="LeftDoubleClick" 
                                                  Command="{Binding EditarRebanhoCommand}" 
                                                  CommandParameter="{Binding RebanhoSelecionado}"/>
                                </DataGrid.InputBindings>
                            </DataGrid>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>