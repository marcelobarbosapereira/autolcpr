<Window x:Class="AutoLCPR.UI.WPF.Views.AlertWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Aviso"
    WindowStartupLocation="CenterScreen"
    Width="420" Height="240"
    Background="#F8F9FA"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStyle="None"
    BorderBrush="#E8EAED"
    BorderThickness="1"
    KeyDown="WindowKeyDown">

    <Border Background="White" BorderBrush="#E8EAED" BorderThickness="1" CornerRadius="8">
        <Grid Background="White">
            <StackPanel Margin="30" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock x:Name="IconText"
                               Text="!"
                               FontSize="36"
                               Foreground="#D5433E"
                               TextAlignment="Center"
                               Margin="0,0,0,10"/>
                    <TextBlock x:Name="TitleText"
                               Text="Aviso"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#202124"
                               TextAlignment="Center"
                               Margin="0,0,0,10"/>
                    <TextBlock x:Name="MessageText"
                               Text="Mensagem"
                               FontSize="13"
                               Foreground="#5F6368"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Button Content="OK"
                        Width="120"
                        Height="36"
                        Background="#1F71E7"
                        Foreground="White"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        HorizontalAlignment="Center"
                        Click="OkClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
